# Copy to .env — docker-compose picks it up automatically. Never commit .env.

# OpenRouter key. Never commit a real value.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=tencent/hy3:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_URL=http://localhost:5173
OPENROUTER_APP_NAME=Leadtech ATS

# Free generated portrait endpoint.
PORTRAIT_IMAGE_URL=https://image.pollinations.ai/prompt
POLLINATIONS_TEXT_URL=https://text.pollinations.ai
POLLINATIONS_TEXT_MODEL=openai
LOCAL_CV_TEXT_ONLY=false

# Optional: GCS bucket for per-write PDF backups (leave empty for local dev).
GCS_BUCKET=

# CORS: comma-separated origins; "*" is fine locally. In the k8s deployment
# this is locked to the app hostname via infra/k8s/config.yaml instead.
ALLOWED_ORIGINS=*
